local downloadedImages = {}
local function getOrDownloadImage(url)
    if not url or url == "" then return "" end
    if downloadedImages[url] then return downloadedImages[url] end
    if not (writefile and isfile and getcustomasset) then
        downloadedImages[url] = url
        return url
    end
    local hash = 0
    for i = 1, #url do
        hash = hash + string.byte(url, i)
    end
    local filename = "cached_img_" .. tostring(hash) .. ".jpg"
    if not isfile(filename) then
        local success, data = pcall(function() return game:HttpGet(url) end)
        if success and data then
            writefile(filename, data)
        end
    end
    if isfile(filename) then
        local asset = getcustomasset(filename)
        downloadedImages[url] = asset
        return asset
    else
        downloadedImages[url] = url
        return url
    end
end

