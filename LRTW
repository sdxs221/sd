 function Library:AddSlider(page, title, min, max, default, callback)
 local row = Instance.new("Frame", page)
 row.Size = UDim2.new(0,318,0,50)
 row.BackgroundColor3 = Color3.fromRGB(255,255,255) row.BackgroundTransparency = 0.94
 Instance.new("UICorner", row).CornerRadius = UDim.new(0,8)

 local label = Instance.new("TextLabel", row)
 label.Size = UDim2.new(0,190,0,20) label.Position = UDim2.new(0,8,0,4)
 label.BackgroundTransparency = 1 label.Font = Enum.Font.SourceSansBold
 label.Text = title label.TextColor3 = Color3.fromRGB(240,240,240) label.TextSize = 12

 local valLabel = Instance.new("TextLabel", row)
 valLabel.Size = UDim2.new(0,40,0,20) valLabel.Position = UDim2.new(1,-48,0,4)
 valLabel.BackgroundTransparency = 1 valLabel.Font = Enum.Font.SourceSansBold
 valLabel.Text = tostring(default) valLabel.TextColor3 = Color3.fromRGB(255,255,255) valLabel.TextSize = 12

 local bar = Instance.new("TextButton", row)
 bar.Size = UDim2.new(0.95,-16,0,4) bar.Position = UDim2.new(0,8,1,-12)
 bar.BackgroundColor3 = Color3.fromRGB(255,255,255) bar.BackgroundTransparency = 0.8 bar.Text = ""
 Instance.new("UICorner", bar).CornerRadius = UDim.new(0,2)

 local fill = Instance.new("Frame", bar)
 fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
 fill.BackgroundColor3 = Color3.fromRGB(255,255,255) fill.BackgroundTransparency = 0.2
 Instance.new("UICorner", fill).CornerRadius = UDim.new(0,2)

 local knob = Instance.new("Frame", bar )
 knob.Size = UDim2.new(0,10,0,10)
 knob.Position = UDim2.new((default-min)/(max-min),-5,0.5,-5)
 knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
 Instance.new("UICorner", knob).CornerRadius = UDim.new(0,5)

 local dragging = false
 local function update(input)
 local p = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
 local v = math.round(min + p * (max - min))
 valLabel.Text = tostring(v)
 fill.Size = UDim2.new(p,0,1,0)
 knob.Position = UDim2.new(p,-5,0.5,-5)
 if callback then callback(v) end
 end
 bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(i) end end)
 UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end end)
 UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
 end

