local function downloadImage(url, fileName)
    if writefile and isfile and getcustomasset then
        if not isfile(fileName) then
            local success, data = pcall(function() return game:HttpGet(url) end)
            if success and data then
                writefile(fileName, data)
            end
        end
        if isfile(fileName) then
            return getcustomasset(fileName)
        end
    end
    return url
end

local UI = {}
UI.__index = UI

function UI.New(config)
    config = config or {}
    local self = setmetatable({}, UI)

    self.Config = {
        BackgroundImage = config.BackgroundImage or "rbxassetid://0",
        Title = config.Title or "LIQUID GLASS",
        DefaultTab = config.DefaultTab or "首页",
        NotificationDuration = config.NotificationDuration or 4,
    }

    local bgAsset = self.Config.BackgroundImage
    if bgAsset:match("^https?://") then
        local fileName = "UI_Background.jpg"
        bgAsset = downloadImage(bgAsset, fileName)
    end
    self.Config.ResolvedImage = bgAsset

    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = "LiquidGlassUI"
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.ScreenGui.DisplayOrder = 999
    self.ScreenGui.Parent = playerGui

    self.ActiveTab = nil
    self.Tabs = {}
    self.TabButtons = {}
    self.Buttons = {}
    self.ActiveNotifications = {}
    self.UIOpen = false
    self.LastPosition = UDim2.new(0.5, -240, 0.5, -135)

    self:_BuildUI()

    if self.Config.DefaultTab and self.Tabs[self.Config.DefaultTab] then
        self:SwitchTab(self.Config.DefaultTab)
    end

    return self
end

