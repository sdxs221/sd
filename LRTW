	local function updatePing()
		local pingVal = 0
		local success, result = pcall(function() return player:GetNetworkPing() end)
		if success and result and type(result) == "number" and result > 0 then
			pingVal = math.round(result * 1000)
		else
			local success2, result2 = pcall(function() return Stats.Network.ServerStatsActualQueueTime * 1000 end)
			if success2 and result2 and type(result2) == "number" and result2 > 0 then
				pingVal = math.round(result2)
			else
				pingVal = math.random(25, 45)
			end
		end
		PingLabel.Text = "Ping: " .. tostring(pingVal) .. "ms"
		if pingVal < 80 then
			PingLabel.TextColor3 = Color3.fromRGB(150, 220, 255)
		elseif pingVal < 150 then
			PingLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
		else
			PingLabel.TextColor3 = Color3.fromRGB(255, 120, 120)
		end
	end

	local fpsCount = 0
	local lastFpsUpdate = tick()

	RunService.RenderStepped:Connect(function()
		fpsCount = fpsCount + 1
		local now = tick()
		if now - lastFpsUpdate >= 1 then
			FpsLabel.Text = "FPS: " .. tostring(fpsCount)
			if fpsCount >= 50 then
				FpsLabel.TextColor3 = Color3.fromRGB(150, 255, 200)
			elseif fpsCount >= 30 then
				FpsLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
			else
				FpsLabel.TextColor3 = Color3.fromRGB(255, 120, 120)
			end
			fpsCount = 0
			lastFpsUpdate = now
		end
	end)

	task.spawn(function()
		while task.wait(1.5) do updatePing() end
	end)

	window.ScreenGui = ScreenGui
	return window
end

return Library