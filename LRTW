    self.UIOpen = false

    self:CloseAllPopups()

    TweenService:Create(self.Island, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {
        Size = UDim2.new(0, 220, 0, 26)
    }):Play()
    self.ToggleButton.Text = "OPEN"
    self.ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)

