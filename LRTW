            placeholderLabel.Visible = true
            pillsContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
        else
            placeholderLabel.Visible = false
            local totalWidth = 0

            for _, key in ipairs(listKeys) do
                local pill = Instance.new("Frame")
                pill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                pill.BackgroundTransparency = 0.75
                pill.BorderSizePixel = 0
                pill.ZIndex = 5
                pill.Parent = pillsContainer

                local pillCorner = Instance.new("UICorner")
                pillCorner.CornerRadius = UDim.new(0, 4)
                pillCorner.Parent = pill

                local pillStroke = Instance.new("UIStroke")
                pillStroke.Color = Color3.fromRGB(255, 255, 255)
                pillStroke.Transparency = 0.6
                pillStroke.Thickness = 1
                pillStroke.Parent = pill

                local pLabel = Instance.new("TextLabel")
                pLabel.Size = UDim2.new(1, -16, 1, 0)
                pLabel.Position = UDim2.new(0, 4, 0, 0)
                pLabel.BackgroundTransparency = 1
                pLabel.Font = Enum.Font.SourceSansBold
                pLabel.Text = key
                pLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                pLabel.TextSize = 9
                pLabel.ZIndex = 6
                pLabel.Parent = pill

                local cancelBtn = Instance.new("TextButton")
                cancelBtn.Size = UDim2.new(0, 12, 0, 12)
                cancelBtn.Position = UDim2.new(1, -14, 0.5, -6)
                cancelBtn.BackgroundTransparency = 1
                cancelBtn.Font = Enum.Font.SourceSansBold
                cancelBtn.Text = "×"
                cancelBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
                cancelBtn.TextSize = 10
                cancelBtn.ZIndex = 6
                cancelBtn.Parent = pill

                local textWidth = TextService:GetTextSize(key, 9, Enum.Font.SourceSansBold, Vector2.new(100, 100)).X
                local pWidth = textWidth + 20
                pill.Size = UDim2.new(0, pWidth, 0.75, 0)

                totalWidth = totalWidth + pWidth + 4

                cancelBtn.MouseButton1Click:Connect(function()
                    selectedSet[key] = nil
                    refreshPills()

                    local rowBtn = optionButtons[key]
                    if rowBtn then
                        local checkMark = rowBtn:FindFirstChild("CheckMark")
                        if checkMark then checkMark.Visible = false end
                        rowBtn.TextColor3 = Color3.fromRGB(180, 180, 190)
                    end

                    if callback then
                        local activeList = {}
                        for k, active in pairs(selectedSet) do
                            if active then table.insert(activeList, k) end
                        end
                        callback(activeList)
                    end
                end)
            end

            pillsContainer.CanvasSize = UDim2.new(0, totalWidth, 0, 0)
        end
    end

    local function createOptionRow(optName)
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(0.98, 0, 0, 26)
        optBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        optBtn.BackgroundTransparency = 1
        optBtn.BorderSizePixel = 0
        optBtn.Font = Enum.Font.SourceSansBold
        optBtn.Text = "   " .. optName
        optBtn.TextColor3 = selectedSet[optName] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)
        optBtn.TextSize = 11
        optBtn.TextXAlignment = Enum.TextXAlignment.Left
        optBtn.AutoButtonColor = false
        optBtn.ZIndex = 15001
        optBtn.Parent = dropdownList

        local optCorner = Instance.new("UICorner")
        optCorner.CornerRadius = UDim.new(0, 4)
        optCorner.Parent = optBtn

        local checkMark = Instance.new("TextLabel")
        checkMark.Name = "CheckMark"
        checkMark.Size = UDim2.new(0, 24, 1, 0)
        checkMark.Position = UDim2.new(1, -28, 0, 0)
        checkMark.BackgroundTransparency = 1
        checkMark.Font = Enum.Font.SourceSansBold
        checkMark.Text = "✓"
        checkMark.TextColor3 = Color3.fromRGB(255, 255, 255)
        checkMark.TextSize = 11
        checkMark.Visible = selectedSet[optName] and true or false
        checkMark.ZIndex = 15002
        checkMark.Parent = optBtn

        optionButtons[optName] = optBtn

        optBtn.MouseEnter:Connect(function()
            TweenService:Create(optBtn, TweenInfo.new(0.12), {
                BackgroundTransparency = 0.88,
                TextColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
        end)

        optBtn.MouseLeave:Connect(function()
            local targetColor = selectedSet[optName] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 190)
            TweenService:Create(optBtn, TweenInfo.new(0.12), {
                BackgroundTransparency = 1,
                TextColor3 = targetColor
            }):Play()
        end)

        optBtn.MouseButton1Click:Connect(function()
            if selectedSet[optName] then
                selectedSet[optName] = nil
                checkMark.Visible = false
                optBtn.TextColor3 = Color3.fromRGB(180, 180, 190)
            else
                selectedSet[optName] = true
                checkMark.Visible = true
                optBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            end

            refreshPills()

            if callback then
                local activeList = {}
                for k, active in pairs(selectedSet) do
                    if active then table.insert(activeList, k) end
                end
                callback(activeList)
            end
        end)
    end

    for _, v in ipairs(optionsList) do
        createOptionRow(v)
    end
    refreshPills()

    local function closeThisDropdown()
        isOpen = false
        arrowLabel.Text = "▼"
        local dropdownTween = TweenService:Create(dropdownList, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 120, 0, 0)
        })
        dropdownTween:Play()
        task.spawn(function()
            dropdownTween.Completed:Wait()
            if not isOpen then
                dropdownList.Visible = false
                if self.ActiveDropdownList == dropdownList then
                    self.ActiveDropdownList = nil
                    self.ModalOverlay.Visible = false
                end
            end
        end)
    end

    local function toggleDropdown()
        if isOpen then
            closeThisDropdown()
        else
            if self.ActiveDropdownList and self.CloseActiveDropdownFunc then
                self.CloseActiveDropdownFunc()
            end

            isOpen = true
            self.ActiveDropdownList = dropdownList
            self.CloseActiveDropdownFunc = closeThisDropdown

            local absPos = mainTrigger.AbsolutePosition
            local absSize = mainTrigger.AbsoluteSize

            dropdownList.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 2)
            dropdownList.Visible = true
            arrowLabel.Text = "▲"

            self.ModalOverlay.Visible = true

            local contentHeight = math.min(#optionsList * 28 + 6, 120)
            TweenService:Create(dropdownList, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 120, 0, contentHeight)
            }):Play()
        end
    end

    mainTrigger.MouseButton1Click:Connect(toggleDropdown)

    return row
end

