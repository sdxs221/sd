	local function onInputBegan(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local pos = input.Position
			if ActiveDropdownList and CloseActiveDropdownFunc and ActiveDropdownList.Parent then
				if not (ActiveDropdownList.AbsolutePosition.X <= pos.X and pos.X <= ActiveDropdownList.AbsolutePosition.X + ActiveDropdownList.AbsoluteSize.X
					and ActiveDropdownList.AbsolutePosition.Y <= pos.Y and pos.Y <= ActiveDropdownList.AbsolutePosition.Y + ActiveDropdownList.AbsoluteSize.Y) then
					CloseActiveDropdownFunc()
				end
			end
			if GlobalPickerPanel.Visible then
				if not (GlobalPickerPanel.AbsolutePosition.X <= pos.X and pos.X <= GlobalPickerPanel.AbsolutePosition.X + GlobalPickerPanel.AbsoluteSize.X
					and GlobalPickerPanel.AbsolutePosition.Y <= pos.Y and pos.Y <= GlobalPickerPanel.AbsolutePosition.Y + GlobalPickerPanel.AbsoluteSize.Y) then
					closePicker()
				end
			end
		end
	end
