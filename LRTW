function UI:AddSlider(page, title, minVal, maxVal, defaultVal, callback)
    local row, tLabel = self:_CreateAdaptiveRow(page)
    tLabel.Text = title

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 40, 0, 20)
    valueLabel.Position = UDim2.new(1, -48, 0, 4)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.SourceSansBold
    valueLabel.Text = tostring(defaultVal)
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.TextSize = 12
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = row

    local sliderBar = Instance.new("TextButton")
    sliderBar.Size = UDim2.new(0.95, -16, 0, 4)
    sliderBar.Position = UDim2.new(0, 8, 1, -10)
    sliderBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderBar.BackgroundTransparency = 0.8
    sliderBar.BorderSizePixel = 0
    sliderBar.Text = ""
    sliderBar.Parent = row

    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(0, 2)
    barCorner.Parent = sliderBar

    local fillBar = Instance.new("Frame")
    fillBar.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    fillBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    fillBar.BackgroundTransparency = 0.2
    fillBar.BorderSizePixel = 0
    fillBar.Parent = sliderBar

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 2)
    fillCorner.Parent = fillBar

    local sliderBtn = Instance.new("Frame")
    sliderBtn.Size = UDim2.new(0, 10, 0, 10)
    sliderBtn.Position = UDim2.new((defaultVal - minVal) / (maxVal - minVal), -5, 0.5, -5)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderBtn.Parent = sliderBar

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 5)
    btnCorner.Parent = sliderBtn

    local isDragging = false
    local function updateSlider(input)
        local absoluteSize = sliderBar.AbsoluteSize.X
        local relativeMouseX = input.Position.X - sliderBar.AbsolutePosition.X
        local percentage = math.clamp(relativeMouseX / absoluteSize, 0, 1)

        local exactVal = minVal + (percentage * (maxVal - minVal))
        local roundedVal = math.round(exactVal)

        valueLabel.Text = tostring(roundedVal)
        sliderBtn.Position = UDim2.new(percentage, -5, 0.5, -5)
        fillBar.Size = UDim2.new(percentage, 0, 1, 0)

        if callback then callback(roundedVal) end
    end

    sliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            updateSlider(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    return row
end

