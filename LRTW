	local function switchTab(tabName)
		if activeTab == tabName then return end
		local prevTab = activeTab
		activeTab = tabName
		if prevTab and Pages[prevTab] then
			local oldPage = Pages[prevTab]
			TweenService:Create(oldPage, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				Position = UDim2.new(0, 0, 0, 15)
			}):Play()
			task.delay(0.15, function()
				if activeTab ~= prevTab then oldPage.Visible = false end
			end)
		end
		for name, btn in pairs(Buttons) do
			local container = btn:FindFirstChild("ContentLayoutFrame")
			if name == tabName then
				TweenService:Create(btn, TweenInfo.new(0.2), {
					BackgroundTransparency = 0.8
				}):Play()
				if container then
					for _, child in ipairs(container:GetChildren()) do
						if child:IsA("ImageLabel") then
							TweenService:Create(child, TweenInfo.new(0.2), {
								ImageColor3 = Color3.fromRGB(255, 255, 255),
								ImageTransparency = 0
							}):Play()
						elseif child:IsA("TextLabel") then
							TweenService:Create(child, TweenInfo.new(0.2), {
								TextColor3 = Color3.fromRGB(255, 255, 255)
							}):Play()
						end
					end
				end
			else
				TweenService:Create(btn, TweenInfo.new(0.2), {
					BackgroundTransparency = 1
				}):Play()
				if container then
					for _, child in ipairs(container:GetChildren()) do
						if child:IsA("ImageLabel") then
							TweenService:Create(child, TweenInfo.new(0.2), {
								ImageColor3 = Color3.fromRGB(170, 170, 180),
								ImageTransparency = 0.3
							}):Play()
						elseif child:IsA("TextLabel") then
							TweenService:Create(child, TweenInfo.new(0.2), {
								TextColor3 = Color3.fromRGB(170, 170, 180)
							}):Play()
						end
					end
				end
			end
		end
		local newPage = Pages[tabName]
		if newPage then
			newPage.Visible = true
			newPage.Position = UDim2.new(0, 0, 0, 15)
			TweenService:Create(newPage, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
