        Size = UDim2.new(0, 10, 0, 10),
        Position = UDim2.new(0, 15, 0, 15)
    })
    local transTween = TweenService:Create(self.Canvas, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
        GroupTransparency = 1
    })

