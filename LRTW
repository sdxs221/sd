        label.Text = name
        label.TextColor3 = Color3.fromRGB(170,170,180)
        label.TextSize = 11
        label.TextXAlignment = Enum.TextXAlignment.Left

        TabButtons[name] = btn

        local function switch()
            if currentTab == name then return end
            if currentTab and Pages[currentTab] then
                Pages[currentTab].Visible = false
            end
            currentTab = name
            page.Visible = true
        end

        btn.MouseButton1Click:Connect(switch)

        if not currentTab then switch() end

        return page
    end

