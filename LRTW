 -- FPS & Ping
 local fps = 0
 local last = tick()
 RunService.RenderStepped:Connect(function()
 fps += 1
 if tick() - last >= 1 then
 FpsLabel.Text = "FPS: " .. fps
 fps = 0
 last = tick()
 end
 end)

 spawn(function()
 while wait(1.5) do
 local ping = 30
 local s, p = pcall(function() return player:GetNetworkPing() end)
 if s and p then ping = math.round(p*1000) end
 PingLabel.Text = "Ping: " .. ping .. "ms"
 end
 end)

 return Library
end

