    contentLabel.Parent = notification

    local function adjustHeight()
        local textHeight = TextService:GetTextSize(text, 11, Enum.Font.SourceSans, Vector2.new(236, 999)).Y
        local targetHeight = 28 + textHeight + 10
        notification.Size = UDim2.new(0, 260, 0, math.max(60, targetHeight))
    end
    adjustHeight()

    local function rearrangeNotifications()
        local currentYOffset = -85
        for i = #self.ActiveNotifications, 1, -1 do
            local notif = self.ActiveNotifications[i]
            if notif and notif.Parent then
                local targetY = -85 - (currentYOffset - -85)
                TweenService:Create(notif, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = UDim2.new(1, -275, 1, currentYOffset - notif.Size.Y.Offset)
                }):Play()
                currentYOffset = currentYOffset - notif.Size.Y.Offset - 10
            end
        end
    end

    table.insert(self.ActiveNotifications, notification)
    rearrangeNotifications()

    TweenService:Create(notification, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        GroupTransparency = 0
    }):Play()

    local hasDestroyed = false
    local function destroyNotification()
        if hasDestroyed then return end
        hasDestroyed = true

        for i, v in ipairs(self.ActiveNotifications) do
            if v == notification then
                table.remove(self.ActiveNotifications, i)
                break
            end
        end

        rearrangeNotifications()

        local outTween = TweenService:Create(notification, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 30, notification.Position.Y.Scale, notification.Position.Y.Offset),
            GroupTransparency = 1
        })
        outTween:Play()
        outTween.Completed:Wait()
        notification:Destroy()
    end

    closeBtn.MouseButton1Click:Connect(destroyNotification)

    closeBtn.MouseEnter:Connect(function() closeBtn.TextColor3 = Color3.fromRGB(255, 100, 100) end)
    closeBtn.MouseLeave:Connect(function() closeBtn.TextColor3 = Color3.fromRGB(200, 200, 200) end)

    task.delay(duration, function()
        if notification and notification.Parent then
            destroyNotification()
        end
    end)
end

