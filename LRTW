        local percent = math.clamp(pos / hue.AbsoluteSize.X, 0, 1)
        self._pickerData.Hue = percent
        hCursor.Position = UDim2.new(percent, -3, 0, -2)
        self:_UpdatePickerOutput()
    end

    local function updateVal(input)
        local pos = input.Position.X - val.AbsolutePosition.X
        local percent = math.clamp(pos / val.AbsoluteSize.X, 0, 1)
        self._pickerData.Value = percent
        self._pickerData.Saturation = percent
        vCursor.Position = UDim2.new(percent, -3, 0, -2)
        self:_UpdatePickerOutput()
    end

    local dragHue, dragVal = false, false

    hue.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragHue = true
            updateHue(input)
        end
    end)

    val.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragVal = true
            updateVal(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateHue(input)
        elseif dragVal and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateVal(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragHue = false
            dragVal = false
        end
    end)

    confirm.MouseButton1Click:Connect(function()
        self.Picker.Visible = false
        self.ModalOverlay.Visible = false
        self._pickerData.ActiveButton = nil
        self._pickerData.Callback = nil
    end)

    self._pickerHue = hue
    self._pickerVal = val
end

function UI:_UpdatePickerOutput()
    local h = self._pickerData.Hue
    local s = self._pickerData.Saturation
    local v = self._pickerData.Value
    local color = Color3.fromHSV(h, s, v)

    if self._pickerData.ActiveButton then
        self._pickerData.ActiveButton.BackgroundColor3 = color
    end
    self.RgbLabel.Text = string.format("RGB: %d, %d, %d", math.round(color.R * 255), math.round(color.G * 255), math.round(color.B * 255))

    local baseHueColor = Color3.fromHSV(h, 1, 1)
    self.ValGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(1, baseHueColor)
    })

    if self._pickerData.Callback then
        self._pickerData.Callback(color)
    end
end

function UI:_SetupDragging()
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        self.MainPanel.Position = newPos
        if self.UIOpen then self.LastPosition = newPos end
    end

    self.TitleLabel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = self.MainPanel.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    self.TitleLabel.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

function UI:AddTab(name, iconId)
    local page = Instance.new("ScrollingFrame")
    page.Name = name .. "Page"
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
    page.ScrollBarImageTransparency = 0.5
    page.ScrollingDirection = Enum.ScrollingDirection.Y
    page.ElasticBehavior = Enum.ElasticBehavior.Always
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.Visible = false
    page.Parent = self.ContentContainer

    local pageLayout = Instance.new("UIListLayout")
    pageLayout.FillDirection = Enum.FillDirection.Vertical
    pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    pageLayout.Padding = UDim.new(0, 8)
    pageLayout.Parent = page

    pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 15)
    end)

    self.Tabs[name] = page
    self:_CreateTabButton(name, iconId, #self.TabButtons + 1)

    if not self.ActiveTab then
        self:SwitchTab(name)
    end

    return page
end

