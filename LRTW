 function Library:Notify(title, text, duration)
 duration = duration or 4
 local notif = Instance.new("CanvasGroup")
 notif.Size = UDim2.new(0,260,0,70)
 notif.Position = UDim2.new(1,30,1,-85)
 notif.BackgroundColor3 = Color3.fromRGB(15,15,25)
 notif.BackgroundTransparency = 0.3
 notif.GroupTransparency = 1
 notif.ZIndex = 10000
 notif.Parent = ScreenGui

 Instance.new("UICorner", notif).CornerRadius = UDim.new(0,10)
 local ns = Instance.new("UIStroke", notif)
 ns.Color = Color3.fromRGB(255,255,255) ns.Transparency = 0.75 ns.Thickness = 1

 local tLabel = Instance.new("TextLabel", notif)
 tLabel.Size = UDim2.new(1,-30,0,22) tLabel.Position = UDim2.new(0,12,0,6)
 tLabel.BackgroundTransparency = 1 tLabel.Font = Enum.Font.SourceSansBold
 tLabel.Text = title tLabel.TextColor3 = Color3.fromRGB(255,255,255) tLabel.TextSize = 13

 local closeBtn = Instance.new("TextButton", notif)
 closeBtn.Size = UDim2.new(0,18,0,18) closeBtn.Position = UDim2.new(1,-24,0,8)
 closeBtn.BackgroundTransparency = 1 closeBtn.Text = "×" closeBtn.TextColor3 = Color3.fromRGB(200,200,200) closeBtn.TextSize = 13

 local cLabel = Instance.new("TextLabel", notif)
 cLabel.Size = UDim2.new(1,-24,0,30) cLabel.Position = UDim2.new(0,12,0,28)
 cLabel.BackgroundTransparency = 1 cLabel.Font = Enum.Font.SourceSans
 cLabel.Text = text cLabel.TextColor3 = Color3.fromRGB(210,210,220) cLabel.TextSize = 11
 cLabel.TextWrapped = true

 local th = TextService:GetTextSize(text,11,Enum.Font.SourceSans,Vector2.new(236,999)).Y
 notif.Size = UDim2.new(0,260,0,math.max(60,28+th+10))

 table.insert(activeNotifications, notif)

 local function rearrange()
 local y = -85
 for i = #activeNotifications,1,-1 do
 local n = activeNotifications[i]
 if n and n.Parent then
 TweenService:Create(n, TweenInfo.new(0.35), {Position = UDim2.new(1,-275,1,y-n.Size.Y.Offset)}):Play()
 y = y - n.Size.Y.Offset - 10
 end
 end
 end
 rearrange()

 TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {GroupTransparency = 0}):Play()

 local function destroy()
 for i,v in ipairs(activeNotifications) do if v == notif then table.remove(activeNotifications,i) break end end
 rearrange()
 local out = TweenService:Create(notif, TweenInfo.new(0.35), {Position = UDim2.new(1,30,notif.Position.Y.Scale,notif.Position.Y.Offset), GroupTransparency = 1})
 out:Play() out.Completed:Wait() notif:Destroy()
 end
 closeBtn.MouseButton1Click:Connect(destroy)
 task.delay(duration, destroy)
 end

