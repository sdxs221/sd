        cLabel.TextSize = 11
        cLabel.TextXAlignment = Enum.TextXAlignment.Left
        cLabel.TextYAlignment = Enum.TextYAlignment.Top
        cLabel.TextWrapped = true

        local textHeight = TextService:GetTextSize(text,11,Enum.Font.SourceSans,Vector2.new(236,999)).Y
        notif.Size = UDim2.new(0,260,0,math.max(60,28 + textHeight + 10))

        table.insert(activeNotifications, notif)

        local function rearrange()
            local y = -85
            for i = #activeNotifications,1,-1 do
                local n = activeNotifications[i]
                if n and n.Parent then
                    TweenService:Create(n,TweenInfo.new(0.35,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{
                        Position = UDim2.new(1,-275,1,y - n.Size.Y.Offset)
                    }):Play()
                    y = y - n.Size.Y.Offset - 10
                end
            end
        end

        rearrange()

        TweenService:Create(notif,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{GroupTransparency = 0}):Play()

        local destroyed = false
        local function destroy()
            if destroyed then return end
            destroyed = true
            for i,v in ipairs(activeNotifications) do
                if v == notif then table.remove(activeNotifications,i) break end
            end
            rearrange()
            local out = TweenService:Create(notif,TweenInfo.new(0.35),{Position = UDim2.new(1,30,notif.Position.Y.Scale,notif.Position.Y.Offset), GroupTransparency = 1})
            out:Play()
            out.Completed:Wait()
            notif:Destroy()
        end

        closeBtn.MouseButton1Click:Connect(destroy)
        task.delay(duration, destroy)
    end

