    btnCorner.Parent = btn

    local contentFrame = Instance.new("Frame")
    contentFrame.Name = "ContentLayoutFrame"
    contentFrame.Size = UDim2.new(1, 0, 1, 0)
    contentFrame.BackgroundTransparency = 1
    contentFrame.BorderSizePixel = 0
    contentFrame.Parent = btn

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0, 6)
    layout.Parent = contentFrame

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 8)
    padding.Parent = contentFrame

    if iconId and iconId ~= "" then
        local icon = Instance.new("ImageLabel")
        icon.Name = "TabIcon"
        icon.Size = UDim2.new(0, 13, 0, 13)
        icon.BackgroundTransparency = 1
        icon.Image = iconId
        icon.ImageColor3 = Color3.fromRGB(170, 170, 180)
        icon.ImageTransparency = 0.3
        icon.Parent = contentFrame
    end

    local label = Instance.new("TextLabel")
    label.Name = "TabLabel"
    label.Size = UDim2.new(1, -26, 1, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSansBold
    label.Text = name
    label.TextColor3 = Color3.fromRGB(170, 170, 180)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = contentFrame

    self.TabButtons[name] = btn

    btn.MouseEnter:Connect(function()
        if self.ActiveTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundTransparency = 0.9
            }):Play()
            local icon = contentFrame:FindFirstChild("TabIcon")
            if icon then
                TweenService:Create(icon, TweenInfo.new(0.15), {
                    ImageColor3 = Color3.fromRGB(230, 230, 230),
                    ImageTransparency = 0.1
                }):Play()
            end
            TweenService:Create(label, TweenInfo.new(0.15), {
                TextColor3 = Color3.fromRGB(230, 230, 230)
            }):Play()
        end
    end)

    btn.MouseLeave:Connect(function()
        if self.ActiveTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundTransparency = 1
            }):Play()
            local icon = contentFrame:FindFirstChild("TabIcon")
            if icon then
                TweenService:Create(icon, TweenInfo.new(0.15), {
                    ImageColor3 = Color3.fromRGB(170, 170, 180),
                    ImageTransparency = 0.3
                }):Play()
            end
            TweenService:Create(label, TweenInfo.new(0.15), {
                TextColor3 = Color3.fromRGB(170, 170, 180)
            }):Play()
        end
    end)

    btn.MouseButton1Click:Connect(function()
        self:SwitchTab(name)
    end)
end

function UI:SwitchTab(tabName)
    if self.ActiveTab == tabName then return end

    local prevTab = self.ActiveTab
    self.ActiveTab = tabName

    if prevTab and self.Tabs[prevTab] then
        local oldPage = self.Tabs[prevTab]
        TweenService:Create(oldPage, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(0, 0, 0, 15)
        }):Play()
        task.delay(0.15, function()
            if self.ActiveTab ~= prevTab then oldPage.Visible = false end
        end)
    end

    for name, btn in pairs(self.TabButtons) do
        local container = btn:FindFirstChild("ContentLayoutFrame")
        if name == tabName then
            TweenService:Create(btn, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.8
            }):Play()
            if container then
                for _, child in ipairs(container:GetChildren()) do
                    if child:IsA("ImageLabel") then
                        TweenService:Create(child, TweenInfo.new(0.2), {
                            ImageColor3 = Color3.fromRGB(255, 255, 255),
                            ImageTransparency = 0
                        }):Play()
                    elseif child:IsA("TextLabel") then
                        TweenService:Create(child, TweenInfo.new(0.2), {
