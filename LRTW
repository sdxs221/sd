local function LoadImage(url, filename)
    filename = filename or "LG_BG.jpg"
    local assetId = url
    if writefile and isfile and getcustomasset then
        if not isfile(filename) then
            local success, data = pcall(function() return game:HttpGet(url) end)
            if success and data then writefile(filename, data) end
        end
        if isfile(filename) then assetId = getcustomasset(filename) end
    end
    return assetId
end

