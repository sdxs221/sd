		local fillBar = Instance.new("Frame")
		fillBar.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
		fillBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
