local Library = {}
Library.MainColor = Color3.fromRGB(15, 17, 21)
Library.BackgroundColor = Color3.fromRGB(11, 12, 15)
Library.AccentColor = Color3.fromRGB(0, 240, 255)
Library.OutlineColor = Color3.fromRGB(35, 40, 48)
Library.TextColor = Color3.fromRGB(240, 244, 248)
Library.PlaceholderColor = Color3.fromRGB(100, 110, 125)
Library.Font = Enum.Font.Ubuntu
Library.RegistryMap = {}

local ProtectGui = protectgui or (syn and syn.protect_gui) or (function(gui)
    gui.Parent = cloneref(game:GetService("CoreGui"))
end)

local TweenService = game:GetService("TweenService")
local UserInputService = cloneref(game:GetService("UserInputService"))
local HttpService = cloneref(game:GetService("HttpService"))
local CoreGui = cloneref(game:GetService("CoreGui"))

local ScreenGui = Instance.new("ScreenGui")
ProtectGui(ScreenGui)
ScreenGui.Name = "KeySystem"
ScreenGui.ResetOnSpawn = false
ScreenGui.DisplayOrder = 999999
ScreenGui.Parent = CoreGui

function Library:SaveKey(KeyPath, FileName, key)
    if not (isfolder and makefolder and writefile) then
        warn("File system functions are not available.")
        return
    end
    if not isfolder(KeyPath) then
        makefolder(KeyPath)
    end
    writefile(KeyPath .. "/" .. FileName, HttpService:JSONEncode({key = key}))
end

function Library:LoadKey(KeyPath, FileName)
    if not (isfolder and readfile) then
        warn("File system functions are not available.")
        return nil
    end
    if isfolder(KeyPath) and isfile(KeyPath .. "/" .. FileName) then
        local data = HttpService:JSONDecode(readfile(KeyPath .. "/" .. FileName))
        return data.key
    end
    return nil
end

function Library:Create(Class, Properties)
    local Object = Instance.new(Class)
    for Property, Value in next, Properties do
        Object[Property] = Value
    end
    return Object
end

function Library:CreateLabel(Properties)
    local Label = self:Create('TextLabel', {
        BackgroundTransparency = 1,
        Font = self.Font,
        TextColor3 = self.TextColor,
        TextSize = 14,
        TextStrokeTransparency = 1,
    })
    for Property, Value in next, Properties do
        Label[Property] = Value
    end
    return Label
end

function Library:AddToRegistry(Object, Properties)
    self.RegistryMap[Object] = { Properties = Properties }
end

function Library:Destroy()
    local old = CoreGui:FindFirstChild("KeySystem")
    if old then old:Destroy() end
end

function Library:MakeDraggable(Frame)
    local Dragging, DragInput, DragStart, StartPos

    Frame.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = Input.Position
            StartPos = Frame.Position

            Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                end
            end)
        end
    end)

    Frame.InputChanged:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
            DragInput = Input
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if Input == DragInput and Dragging then
            local Delta = Input.Position - DragStart
            Frame.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
        end
    end)
end

function Library:CreateWindow(Title, Size)
    local Window = {}
    local Library = self

    local Outer = Library:Create('Frame', {
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Library.MainColor,
        BorderSizePixel = 0,
        Position = UDim2.fromScale(0.5, 0.5),
        Size = Size or UDim2.fromOffset(340, 180),
        Visible = true,
        ZIndex = 1,
        Parent = ScreenGui
    })
    
    local OuterCorner = Library:Create('UICorner', {
        CornerRadius = UDim.new(0, 10),
        Parent = Outer
    })
    
    local OuterStroke = Library:Create('UIStroke', {
        Color = Library.OutlineColor,
        Thickness = 1.2,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = Outer
    })

    Library:MakeDraggable(Outer)

    local Inner = Library:Create('Frame', {
        BackgroundColor3 = Library.MainColor,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 1,
        Parent = Outer
    })

    local TitleLabel = Library:CreateLabel({
        Position = UDim2.new(0, 16, 0, 4),
        Size = UDim2.new(1, -32, 0, 30),
        Text = Title,
        TextSize = 15,
        Font = Enum.Font.UbuntuBold,
        TextColor3 = Library.TextColor,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 2,
        Parent = Inner
    })

    local MainSection = Library:Create('Frame', {
        BackgroundColor3 = Library.BackgroundColor,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 12, 0, 38),
        Size = UDim2.new(1, -24, 1, -50),
        ZIndex = 1,
        Parent = Inner
    })
    
    local SectionCorner = Library:Create('UICorner', {
        CornerRadius = UDim.new(0, 8),
        Parent = MainSection
    })
    
    local SectionStroke = Library:Create('UIStroke', {
        Color = Color3.fromRGB(24, 26, 32),
        Thickness = 1,
        Parent = MainSection
    })

    function Window:Close()
        Outer:Destroy()
    end

    function Window:AddTextBox(Text, Position)
        local TextBoxContainer = Library:Create('Frame', {
            BackgroundColor3 = Library.MainColor,
            BorderSizePixel = 0,
            Position = Position,
            Size = UDim2.new(0.9, 0, 0, 36),
            ZIndex = 2,
            Parent = MainSection
        })

        local Corner = Library:Create('UICorner', {
            CornerRadius = UDim.new(0, 6),
            Parent = TextBoxContainer
        })
        
        local BoxStroke = Library:Create('UIStroke', {
            Color = Library.OutlineColor,
            Thickness = 1,
            Parent = TextBoxContainer
        })

        local TextBox = Library:Create('TextBox', {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 12, 0, 0),
            Size = UDim2.new(1, -24, 1, 0),
            Font = Library.Font,
            PlaceholderText = Text,
            PlaceholderColor3 = Library.PlaceholderColor,
            Text = "",
            TextColor3 = Library.TextColor,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 3,
            Parent = TextBoxContainer
        })
        
        TextBox.Focused:Connect(function()
            TweenService:Create(BoxStroke, TweenInfo.new(0.25), { Color = Library.AccentColor }):Play()
        end)

        TextBox.FocusLost:Connect(function()
            TweenService:Create(BoxStroke, TweenInfo.new(0.25), { Color = Library.OutlineColor }):Play()
        end)
        
        return TextBox
    end
    
    function Window:AddButton(Text, Position, Callback)
        local Button = Library:Create('TextButton', {
            BackgroundColor3 = Library.MainColor,
            BorderSizePixel = 0,
            Position = Position,
            Size = UDim2.new(0.42, 0, 0, 34),
            Font = Enum.Font.UbuntuBold,
            Text = Text,
            TextColor3 = Library.TextColor,
            TextSize = 13,
            ZIndex = 2,
            AutoButtonColor = false,
            Parent = MainSection
        })
        
        local Corner = Library:Create('UICorner', {
            CornerRadius = UDim.new(0, 6),
            Parent = Button
        })
        
        local ButtonStroke = Library:Create('UIStroke', {
            Color = Library.OutlineColor,
            Thickness = 1,
            Parent = Button
        })

        local function StartAnimation()
            TweenService:Create(Button, TweenInfo.new(0.2), { BackgroundColor3 = Library.AccentColor }):Play()
            TweenService:Create(Button, TweenInfo.new(0.2), { TextColor3 = Color3.fromRGB(11, 12, 15) }):Play()
            TweenService:Create(ButtonStroke, TweenInfo.new(0.2), { Color = Library.AccentColor }):Play()
        end
    
        local function EndAnimation()
            TweenService:Create(Button, TweenInfo.new(0.2), { BackgroundColor3 = Library.MainColor }):Play()
            TweenService:Create(Button, TweenInfo.new(0.2), { TextColor3 = Library.TextColor }):Play()
            TweenService:Create(ButtonStroke, TweenInfo.new(0.2), { Color = Library.OutlineColor }):Play()
        end
    
        Button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                StartAnimation()
                TweenService:Create(Button, TweenInfo.new(0.1), { Size = UDim2.new(0.40, 0, 0, 32) }):Play()
            end
        end)
    
        Button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                EndAnimation()
                TweenService:Create(Button, TweenInfo.new(0.1), { Size = UDim2.new(0.42, 0, 0, 34) }):Play()
                Callback()
            end
        end)
    
        Button.MouseEnter:Connect(StartAnimation)
        Button.MouseLeave:Connect(EndAnimation)
        
        return Button
    end

    function Window:AddToggle(Text, Position, DefaultState)
        local Toggle = Library:Create('TextButton', {
            BackgroundTransparency = 1,
            Position = UDim2.new(Position.X.Scale, Position.X.Offset, Position.Y.Scale, Position.Y.Offset + 6),
            Size = UDim2.new(0.9, 0, 0, 24),
            Text = "",
            ZIndex = 2,
            Parent = MainSection
        })
    
        local Checkbox = Library:Create('Frame', {
            BackgroundColor3 = Library.MainColor,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 0, 0.5, -10),
            Size = UDim2.fromOffset(20, 20),
            ZIndex = 3,
            Parent = Toggle
        })
    
        local CheckboxCorner = Library:Create('UICorner', {
            CornerRadius = UDim.new(0, 5),
            Parent = Checkbox
        })
        
        local CheckboxStroke = Library:Create('UIStroke', {
            Color = DefaultState and Library.AccentColor or Library.OutlineColor,
            Thickness = 1.2,
            Parent = Checkbox
        })
    
        local Checkmark = Library:Create('TextLabel', {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(1, 0, 1, 0),
            Font = Enum.Font.UbuntuBold,
            Text = "✓",
            TextColor3 = Library.MainColor,
            TextSize = 13,
            TextTransparency = DefaultState and 0 or 1,
            ZIndex = 4,
            Parent = Checkbox
        })
        
        if DefaultState then Checkbox.BackgroundColor3 = Library.AccentColor end
    
        local Label = Library:CreateLabel({
            Position = UDim2.new(0, 28, 0, 0),
            Size = UDim2.new(1, -28, 1, 0),
            Text = Text,
            TextSize = 13,
            TextColor3 = Library.TextColor,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 3,
            Parent = Toggle
        })
    
        local State = DefaultState
        local IsAnimating = false

        local function ToggleState(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if not IsAnimating then
                    IsAnimating = true
                    State = not State
                    
                    local targetTransparency = State and 0 or 1
                    local targetBgColor = State and Library.AccentColor or Library.MainColor
                    local targetStrokeColor = State and Library.AccentColor or Library.OutlineColor
                    
                    TweenService:Create(Checkmark, TweenInfo.new(0.18), { TextTransparency = targetTransparency }):Play()
                    TweenService:Create(Checkbox, TweenInfo.new(0.18), { BackgroundColor3 = targetBgColor }):Play()
                    TweenService:Create(CheckboxStroke, TweenInfo.new(0.18), { Color = targetStrokeColor }):Play()
                    
                    task.wait(0.18)
                    IsAnimating = false
                end
            end
        end
    
        Toggle.InputBegan:Connect(ToggleState)
    
        return {
            GetState = function() return State end,
            SetState = function(NewState)
                if not IsAnimating and State ~= NewState then
                    IsAnimating = true
                    State = NewState
                    local targetTransparency = State and 0 or 1
                    local targetBgColor = State and Library.AccentColor or Library.MainColor
                    local targetStrokeColor = State and Library.AccentColor or Library.OutlineColor
                    
                    TweenService:Create(Checkmark, TweenInfo.new(0.18), { TextTransparency = targetTransparency }):Play()
                    TweenService:Create(Checkbox, TweenInfo.new(0.18), { BackgroundColor3 = targetBgColor }):Play()
                    TweenService:Create(CheckboxStroke, TweenInfo.new(0.18), { Color = targetStrokeColor }):Play()
                    
                    task.wait(0.18)
                    IsAnimating = false
                end
            end,
            Destroy = function()
                Toggle:Destroy()
            end
        }
    end    

    Window.Outer = Outer
    return Window
end

return Library
