    function Window:AddButton(Text, Callback)
        local Button = Library:Create('TextButton', {
            BackgroundColor3 = Library.MainColor,
            BorderSizePixel = 0,
            Size = UDim2.new(1, -10, 0, 42),
            Font = Enum.Font.UbuntuBold,
            Text = Text,
            TextColor3 = Library.TextColor,
            TextSize = 14,
            ZIndex = 3,
            AutoButtonColor = false,
            Parent = MainSection
        })
        
        local Corner = Library:Create('UICorner', {
            CornerRadius = UDim.new(0, 8),
            Parent = Button
        })
        
        local ButtonStroke = Library:Create('UIStroke', {
            Color = Library.OutlineColor,
            Thickness = 1.2,
            Parent = Button
        })

        local function StartAnimation()
            TweenService:Create(Button, TweenInfo.new(0.15), { BackgroundColor3 = Library.AccentColor }):Play()
            TweenService:Create(ButtonStroke, TweenInfo.new(0.15), { Color = Library.AccentColor }):Play()
        end
    
        local function EndAnimation()
            TweenService:Create(Button, TweenInfo.new(0.15), { BackgroundColor3 = Library.MainColor }):Play()
            TweenService:Create(ButtonStroke, TweenInfo.new(0.15), { Color = Library.OutlineColor }):Play()
        end
    
        Button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                StartAnimation()
            end
        end)
    
        Button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                EndAnimation()
                Callback()
            end
        end)
    
        Button.MouseEnter:Connect(StartAnimation)
        Button.MouseLeave:Connect(EndAnimation)
        
        return Button
    end

    function Window:AddToggle(Text, DefaultState)
        local Toggle = Library:Create('TextButton', {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -10, 0, 32),
            Text = "",
            ZIndex = 3,
            Parent = MainSection
        })
    
        local Checkbox = Library:Create('Frame', {
            BackgroundColor3 = Library.MainColor,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 4, 0.5, -11),
            Size = UDim2.fromOffset(22, 22),
            ZIndex = 4,
            Parent = Toggle
        })
    
        local CheckboxCorner = Library:Create('UICorner', {
            CornerRadius = UDim.new(0, 6),
            Parent = Checkbox
        })
        
        local CheckboxStroke = Library:Create('UIStroke', {
            Color = DefaultState and Library.AccentColor or Library.OutlineColor,
            Thickness = 1.2,
            Parent = Checkbox
        })
    
        local Checkmark = Library:Create('TextLabel', {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, -1),
            Size = UDim2.new(1, 0, 1, 0),
            Font = Enum.Font.UbuntuBold,
            Text = "✓",
            TextColor3 = Library.TextColor,
            TextSize = 14,
            TextTransparency = DefaultState and 0 or 1,
            ZIndex = 5,
            Parent = Checkbox
        })
        
        if DefaultState then Checkbox.BackgroundColor3 = Library.AccentColor end
    
        local Label = Library:CreateLabel({
            Position = UDim2.new(0, 38, 0, 0),
            Size = UDim2.new(1, -38, 1, 0),
            Text = Text,
            TextSize = 14,
            TextColor3 = Library.TextColor,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 4,
            Parent = Toggle
        })
    
        local State = DefaultState
        local IsAnimating = false

        local function ToggleState(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if not IsAnimating then
                    IsAnimating = true
                    State = not State
                    
                    local targetTransparency = State and 0 or 1
                    local targetBgColor = State and Library.AccentColor or Library.MainColor
                    local targetStrokeColor = State and Library.AccentColor or Library.OutlineColor
                    
                    TweenService:Create(Checkmark, TweenInfo.new(0.15), { TextTransparency = targetTransparency }):Play()
                    TweenService:Create(Checkbox, TweenInfo.new(0.15), { BackgroundColor3 = targetBgColor }):Play()
                    TweenService:Create(CheckboxStroke, TweenInfo.new(0.15), { Color = targetStrokeColor }):Play()
                    
                    task.wait(0.15)
                    IsAnimating = false
                end
            end
        end
    
        Toggle.InputBegan:Connect(ToggleState)
    
        return {
            GetState = function() return State end,
            SetState = function(NewState)
                if not IsAnimating and State ~= NewState then
                    IsAnimating = true
                    State = NewState
                    local targetTransparency = State and 0 or 1
                    local targetBgColor = State and Library.AccentColor or Library.MainColor
                    local targetStrokeColor = State and Library.AccentColor or Library.OutlineColor
                    
                    TweenService:Create(Checkmark, TweenInfo.new(0.15), { TextTransparency = targetTransparency }):Play()
                    TweenService:Create(Checkbox, TweenInfo.new(0.15), { BackgroundColor3 = targetBgColor }):Play()
                    TweenService:Create(CheckboxStroke, TweenInfo.new(0.15), { Color = targetStrokeColor }):Play()
                    
                    task.wait(0.15)
                    IsAnimating = false
                end
            end,
            Destroy = function()
                Toggle:Destroy()
            end
        }
    end    

