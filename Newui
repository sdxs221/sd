            for optionName, optBtn in pairs(buttonsTable) do
                if currentSelectedText and optionName == currentSelectedText then
                    optBtn.TextColor3 = Color3.fromHex("#5C6BC0")
                else
                    optBtn.TextColor3 = Color3.fromHex("#555555")
                end
            end
