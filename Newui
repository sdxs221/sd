    function pageMethods:AddSlider(title: string, minV: number, maxV: number, defV: number, callback: (number) -> ())
        local card = Instance.new("Frame")
        card.Name = "FunctionalCard"
        card.Size = UDim2.new(1, 0, 0, 42)
        card.BackgroundColor3 = Color3.fromHex("#F5F7FA")
        card.Parent = scroll
        Instance.new("UICorner", card).CornerRadius = UDim.new(0.5, 0) 
        local stroke = Instance.new("UIStroke", card)
        stroke.Color = Color3.fromHex("#E4E8ED")

        local info = Instance.new("TextLabel", card)
        info.Text = title .. ": " .. defV
        info.Size = UDim2.new(0.5, 0, 1, 0)
        info.Position = UDim2.fromOffset(18, 0)
        info.TextColor3 = Color3.fromHex("#333333")
        info.TextSize = 13
        info.Font = Enum.Font.SourceSansBold
        info.TextXAlignment = Enum.TextXAlignment.Left
        info.BackgroundTransparency = 1

        local track = Instance.new("TextButton", card)
        track.Text = ""
        track.Size = UDim2.new(0.4, 0, 0, 6)
        track.AnchorPoint = Vector2.new(1, 0.5)
        track.Position = UDim2.new(1, -20, 0.5, 0)
        track.BackgroundColor3 = Color3.fromHex("#E1E5EA")
        Instance.new("UICorner", track).CornerRadius = UDim.new(0.5, 0)

        local sliderBtn = Instance.new("Frame", track)
        sliderBtn.Size = UDim2.fromOffset(14, 14)
        sliderBtn.AnchorPoint = Vector2.new(0.5, 0.5)
        sliderBtn.Position = UDim2.fromScale((defV - minV)/(maxV - minV), 0.5)
        sliderBtn.BackgroundColor3 = Color3.new(1, 1, 1)
        Instance.new("UICorner", sliderBtn).CornerRadius = UDim.new(0.5, 0)
        local bstroke = Instance.new("UIStroke", sliderBtn)
        bstroke.Color = Color3.fromHex("#5C6BC0")

        local sliding = false
        local function Update(input)
            local per = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local val = math.floor(minV + (maxV - minV) * per)
            sliderBtn.Position = UDim2.fromScale(per, 0.5)
            info.Text = title .. ": " .. val
            callback(val)
        end
        track.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true Update(input) end end)
        UserInputService.InputChanged:Connect(function(input) if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then Update(input) end end)
        UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end end)
    end

