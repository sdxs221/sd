    scroll.Parent = self.ContentFrame
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 8) 
    listLayout.Parent = scroll

    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 2)
    padding.PaddingBottom = UDim.new(0, 12)
    padding.PaddingLeft = UDim.new(0, 2)
    padding.PaddingRight = UDim.new(0, 8)
    padding.Parent = scroll

    local tabCard = Instance.new("Frame", self.LeftTabScroll)
    tabCard.Size = UDim2.new(1, -4, 0, 34)
    tabCard.BackgroundColor3 = (tabIndex == 1) and Color3.fromRGB(0, 240, 255) or Color3.fromRGB(16, 22, 34)
    Instance.new("UICorner", tabCard).CornerRadius = UDim.new(0, 6)
    
    local TabStroke = Instance.new("UIStroke", tabCard)
    TabStroke.Color = (tabIndex == 1) and Color3.fromRGB(0, 240, 255) or Color3.fromRGB(35, 48, 74)
    TabStroke.Thickness = 1

    local btn = Instance.new("TextButton", tabCard)
    btn.Text = tabName
    btn.Size = UDim2.fromScale(1, 1)
    btn.BackgroundTransparency = 1
    btn.TextColor3 = (tabIndex == 1) and Color3.fromRGB(11, 15, 23) or Color3.fromRGB(160, 175, 195)
    btn.TextSize = 13
    btn.Font = Enum.Font.UbuntuBold

    local function SwitchToTab()
        if self.CurrentTab == tabIndex then return end
        local oldPage = self.Pages[self.CurrentTab]
        if oldPage then oldPage.Visible = false end
        
        self.CurrentTab = tabIndex
        scroll.Position = UDim2.fromScale(0.04, 0)
        scroll.Visible = true
        TweenService:Create(scroll, TWEEN_FAST, {Position = UDim2.fromScale(0, 0)}):Play()

        for idx, child in ipairs(self.Tabs) do
            local isSelf = (idx == tabIndex)
            TweenService:Create(child, TWEEN_FAST, {BackgroundColor3 = isSelf and Color3.fromRGB(0, 240, 255) or Color3.fromRGB(16, 22, 34)}):Play()
            child:FindFirstChildOfClass("UIStroke").Color = isSelf and Color3.fromRGB(0, 240, 255) or Color3.fromRGB(35, 48, 74)
            local textBtn = child:FindFirstChildOfClass("TextButton")
            if textBtn then
                TweenService:Create(textBtn, TWEEN_FAST, {TextColor3 = isSelf and Color3.fromRGB(11, 15, 23) or Color3.fromRGB(160, 175, 195)}):Play()
            end
        end
    end

    btn.Activated:Connect(SwitchToTab)
    table.insert(self.Tabs, tabCard)
    table.insert(self.Pages, scroll)

