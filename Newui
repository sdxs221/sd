    function pageMethods:AddSlider(title: string, minV: number, maxV: number, defV: number, callback: (number) -> ())
        local card = Instance.new("Frame", scroll)
        card.Size = UDim2.new(1, 0, 0, 42)
        card.BackgroundColor3 = Color3.fromRGB(16, 22, 34)
        Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
        Instance.new("UIStroke", card).Color = Color3.fromRGB(35, 48, 74)

        local info = Instance.new("TextLabel", card)
        info.Text = title .. ": " .. defV
        info.Size = UDim2.new(0.45, 0, 1, 0)
        info.Position = UDim2.fromOffset(14, 0)
        info.TextColor3 = Color3.fromRGB(230, 238, 245)
        info.TextSize = 13
        info.Font = Enum.Font.Ubuntu
        info.TextXAlignment = Enum.TextXAlignment.Left
        info.BackgroundTransparency = 1

        local track = Instance.new("TextButton", card)
        track.Text = ""
        track.Size = UDim2.new(0.45, 0, 0, 6)
        track.AnchorPoint = Vector2.new(1, 0.5)
        track.Position = UDim2.new(1, -14, 0.5, 0)
        track.BackgroundColor3 = Color3.fromRGB(25, 35, 53)
        Instance.new("UICorner", track).CornerRadius = UDim.new(0.5, 0)

        local progress = Instance.new("Frame", track)
        progress.Size = UDim2.fromScale((defV - minV)/(maxV - minV), 1)
        progress.BackgroundColor3 = Color3.fromRGB(0, 240, 255)
        Instance.new("UICorner", progress).CornerRadius = UDim.new(0.5, 0)

        local sliderBtn = Instance.new("Frame", track)
        sliderBtn.Size = UDim2.fromOffset(12, 12)
        sliderBtn.AnchorPoint = Vector2.new(0.5, 0.5)
        sliderBtn.Position = UDim2.fromScale((defV - minV)/(maxV - minV), 0.5)
        sliderBtn.BackgroundColor3 = Color3.fromRGB(240, 245, 250)
        Instance.new("UICorner", sliderBtn).CornerRadius = UDim.new(0.5, 0)
        local bstroke = Instance.new("UIStroke", sliderBtn)
        bstroke.Color = Color3.fromRGB(0, 240, 255)

        local sliding = false
        local function Update(input)
            local per = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local val = math.floor(minV + (maxV - minV) * per)
            sliderBtn.Position = UDim2.fromScale(per, 0.5)
            progress.Size = UDim2.fromScale(per, 1)
            info.Text = title .. ": " .. val
            callback(val)
        end
        
        track.InputBegan:Connect(function(input) 
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
                sliding = true 
                Update(input) 
            end 
        end)
        UserInputService.InputChanged:Connect(function(input) 
            if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then 
                Update(input) 
            end 
        end)
        UserInputService.InputEnded:Connect(function(input) 
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
                if sliding then
                    sliding = false 
                    local curVal = math.floor(minV + (maxV - minV) * math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1))
                    parentLib:IslandNotify("值已调至: " .. curVal)
                end
            end 
        end)
    end

