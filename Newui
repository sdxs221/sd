function Library:CreateTab(tabName: string)
    local tabIndex = #self.Tabs + 1
    
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.fromScale(1, 1)
    scroll.Position = UDim2.fromScale(0, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 2 
    scroll.ScrollBarImageColor3 = Color3.fromHex("#D0D5DD")
    scroll.ScrollingDirection = Enum.ScrollingDirection.Y
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.Visible = (tabIndex == 1)
    scroll.Parent = self.ContentFrame

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 8) 
    listLayout.Parent = scroll

    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 5)
    padding.PaddingBottom = UDim.new(0, 20)
    padding.PaddingLeft = UDim.new(0, 6)
    padding.PaddingRight = UDim.new(0, 6)
    padding.Parent = scroll

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.fromOffset(0, listLayout.AbsoluteContentSize.Y + 30)
    end)

    local tabCard = Instance.new("Frame", self.LeftTabScroll)
    tabCard.Size = UDim2.new(1, -5, 0, 32)
    tabCard.BackgroundColor3 = (tabIndex == 1) and Color3.fromHex("#5C6BC0") or Color3.fromHex("#E8EBF2")
    Instance.new("UICorner", tabCard).CornerRadius = UDim.new(0.5, 0)

    local btn = Instance.new("TextButton", tabCard)
    btn.Text = tabName
    btn.Size = UDim2.fromScale(1, 1)
    btn.BackgroundTransparency = 1
    btn.TextColor3 = (tabIndex == 1) and Color3.fromHex("#FFFFFF") or Color3.fromHex("#5A6B7C")
    btn.TextSize = 12
    btn.Font = Enum.Font.SourceSansBold

    local function SwitchToTab()
        if self.CurrentTab == tabIndex then return end
        
        local oldPage = self.Pages[self.CurrentTab]
        if oldPage then oldPage.Visible = false end
        
        self.CurrentTab = tabIndex
        
        scroll.Position = UDim2.fromScale(0.1, 0)
        scroll.Visible = true
        TweenService:Create(scroll, TWEEN_INFO_PAGE, {Position = UDim2.fromScale(0, 0)}):Play()

        for _, child in ipairs(self.LeftTabScroll:GetChildren()) do
            if child:IsA("Frame") then
                local isSelf = (child == tabCard)
                TweenService:Create(child, TWEEN_INFO_FAST, {BackgroundColor3 = isSelf and Color3.fromHex("#5C6BC0") or Color3.fromHex("#E8EBF2")}):Play()
                local textBtn = child:FindFirstChildOfClass("TextButton")
                if textBtn then
                    TweenService:Create(textBtn, TWEEN_INFO_FAST, {TextColor3 = isSelf and Color3.fromHex("#FFFFFF") or Color3.fromHex("#5A6B7C")}):Play()
                end
            end
        end
    end

    btn.Activated:Connect(SwitchToTab)

    table.insert(self.Tabs, tabCard)
    table.insert(self.Pages, scroll)

