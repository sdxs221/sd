        listScroll.ZIndex = 12

        local internalLayout = Instance.new("UIListLayout", listScroll)
        internalLayout.SortOrder = Enum.SortOrder.LayoutOrder
        internalLayout.Padding = UDim.new(0, 2)

        for i, optionName in ipairs(options) do
            local optBtn = Instance.new("TextButton", listScroll)
            optBtn.Text = "   " .. optionName
            optBtn.Size = UDim2.new(1, 0, 0, 24)
            optBtn.BackgroundTransparency = 1
            optBtn.TextColor3 = Color3.fromRGB(175, 190, 210)
            optBtn.TextSize = 12
            optBtn.Font = Enum.Font.Ubuntu
            optBtn.TextXAlignment = Enum.TextXAlignment.Left
            optBtn.LayoutOrder = i
            optBtn.ZIndex = 13

            optBtn.Activated:Connect(function()
                currentSelectedText = optionName
                boxBtn.Text = optionName
                boxBtn.TextColor3 = Color3.fromRGB(0, 240, 255)
                callback(optionName)
                isOpened = false
                arrow.Text = "▼"
                listScroll.Visible = false
                TweenService:Create(card, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 42)}):Play()
                parentLib:IslandNotify("已选择选项: " .. optionName)
            end)
        end

        boxBtn.Activated:Connect(function()
            isOpened = not isOpened
            if isOpened then
                arrow.Text = "▲"
                listScroll.Visible = true
                TweenService:Create(card, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 134)}):Play()
            else
                arrow.Text = "▼"
                listScroll.Visible = false
                TweenService:Create(card, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, 42)}):Play()
            end
        end)
    end

    function pageMethods:AddButton(text: string, callback: () -> ())
        local card = Instance.new("Frame", scroll)
        card.Size = UDim2.new(1, 0, 0, 42)
        card.BackgroundColor3 = Color3.fromRGB(16, 22, 34)
        Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
        Instance.new("UIStroke", card).Color = Color3.fromRGB(35, 48, 74)

        local clickBtn = Instance.new("TextButton", card)
        clickBtn.Text = text
        clickBtn.Size = UDim2.new(1, -24, 0, 28)
        clickBtn.Position = UDim2.fromScale(0.5, 0.5)
        clickBtn.AnchorPoint = Vector2.new(0.5, 0.5)
        clickBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 53)
        clickBtn.TextColor3 = Color3.fromRGB(0, 240, 255)
        clickBtn.TextSize = 13
        clickBtn.Font = Enum.Font.UbuntuBold
        Instance.new("UICorner", clickBtn).CornerRadius = UDim.new(0, 5)
        local BtnStroke = Instance.new("UIStroke", clickBtn)
        BtnStroke.Color = Color3.fromRGB(0, 240, 255)
        BtnStroke.Thickness = 1

        clickBtn.Activated:Connect(function()
            clickBtn.Size = UDim2.new(1, -32, 0, 24)
            TweenService:Create(clickBtn, TWEEN_FAST, {Size = UDim2.new(1, -24, 0, 28)}):Play()
            callback()
            parentLib:IslandNotify("已触发点击: " .. text)
        end)
    end

    return pageMethods
end

return Library
