local TWEEN_FAST = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_BOUNCE = TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local TWEEN_ISLAND = TweenInfo.new(0.35, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)

local function MakeDraggable(gui: Frame)
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            TweenService:Create(gui, TWEEN_FAST, {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }):Play()
        end
    end)
end

function Library:IslandNotify(message: string)
    if not self.Island then
        self.Island = Instance.new("Frame", self.ScreenGui)
        self.Island.Name = "DynamicIsland"
        self.Island.AnchorPoint = Vector2.new(0.5, 0)
        self.Island.BackgroundColor3 = Color3.fromRGB(11, 15, 23)
        self.Island.BorderSizePixel = 0
        self.Island.ZIndex = 100
        
        local IslandCorner = Instance.new("UICorner", self.Island)
        IslandCorner.CornerRadius = UDim.new(0.5, 0)
        
        local IslandStroke = Instance.new("UIStroke", self.Island)
        IslandStroke.Color = Color3.fromRGB(35, 48, 74)
        IslandStroke.Thickness = 1.2
        
        local Content = Instance.new("TextLabel", self.Island)
        Content.Name = "Msg"
        Content.Size = UDim2.new(1, -24, 1, 0)
        Content.Position = UDim2.fromOffset(12, 0)
        Content.BackgroundTransparency = 1
        Content.TextColor3 = Color3.fromRGB(0, 240, 255)
        Content.TextSize = 13
        Content.Font = Enum.Font.UbuntuBold
        Content.TextXAlignment = Enum.TextXAlignment.Center
        Content.TextTransparency = 1
        Content.ZIndex = 101
    end
    
    local Island = self.Island
    local Msg = Island.Msg
    Msg.Text = message
    
    Island.Size = UDim2.fromOffset(40, 20)
    Island.Position = UDim2.new(0.5, 0, 0, -30)
    Island.Visible = true
    
    TweenService:Create(Island, TWEEN_ISLAND, {Position = UDim2.new(0.5, 0, 0, 15), Size = UDim2.fromOffset(240, 36)}):Play()
    task.wait(0.15)
    TweenService:Create(Msg, TWEEN_FAST, {TextTransparency = 0}):Play()
    
    task.wait(2.2)
    
    TweenService:Create(Msg, TWEEN_FAST, {TextTransparency = 1}):Play()
    task.wait(0.1)
    local shrink = TweenService:Create(Island, TWEEN_ISLAND, {Size = UDim2.fromOffset(40, 20), Position = UDim2.new(0.5, 0, 0, -30)})
    shrink:Play()
    shrink.Completed:Connect(function()
        Island.Visible = false
    end)
end

