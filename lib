    btn.Text = tabName
    btn.Size = UDim2.fromScale(1, 1)
    btn.BackgroundTransparency = 1
    btn.TextColor3 = (tabIndex == 1) and Color3.fromHex("#FFFFFF") or Color3.fromHex("#888D9D")
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 6

    local function SwitchToTab()
        if self.CurrentTab == tabIndex then return end
        local oldPage = self.Pages[self.CurrentTab]
        if oldPage then oldPage.Visible = false end
        
        self.CurrentTab = tabIndex
        scroll.Position = UDim2.fromScale(0.03, 0)
        scroll.Visible = true
        TweenService:Create(scroll, TWEEN_INFO_PAGE, {Position = UDim2.fromScale(0, 0)}):Play()

        for _, child in ipairs(self.LeftTabScroll:GetChildren()) do
            if child:IsA("Frame") then
                local isSelf = (child == tabCard)
                TweenService:Create(child, TWEEN_INFO_FAST, {BackgroundColor3 = isSelf and Color3.fromHex("#3F51B5") or Color3.fromHex("#15161C")}):Play()
                local stroke = child:FindFirstChildOfClass("UIStroke")
                if stroke then
                    TweenService:Create(stroke, TWEEN_INFO_FAST, {Color = isSelf and Color3.fromHex("#5C6BC0") or Color3.fromHex("#22232A")}):Play()
                end
                local textBtn = child:FindFirstChildOfClass("TextButton")
                if textBtn then
                    TweenService:Create(textBtn, TWEEN_INFO_FAST, {TextColor3 = isSelf and Color3.fromHex("#FFFFFF") or Color3.fromHex("#888D9D")}):Play()
                end
            end
        end
    end

    btn.Activated:Connect(SwitchToTab)
    table.insert(self.Tabs, tabCard)
    table.insert(self.Pages, scroll)

