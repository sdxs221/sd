            optBtn.LayoutOrder = i
            optBtn.ZIndex = 13

            optionButtons[optionName] = optBtn

            optBtn.Activated:Connect(function()
                if selectedItems[optionName] then
                    selectedItems[optionName] = nil
                else
                    selectedItems[optionName] = true
                end
                UpdateDisplay()
            end)
        end

        UpdateDisplay()

        boxBtn.Activated:Connect(function()
            isOpened = not isOpened
            if isOpened then
                arrow.Text = "▲"
                listScroll.Visible = true
                TweenService:Create(card, TWEEN_INFO_FAST, {Size = UDim2.new(1, 0, 0, 130)}):Play()
            else
                arrow.Text = "▼"
                listScroll.Visible = false
                TweenService:Create(card, TWEEN_INFO_FAST, {Size = UDim2.new(1, 0, 0, 40)}):Play()
            end
        end)
    end

    function pageMethods:AddButton(text: string, callback: () -> ())
        local card = Instance.new("Frame", scroll)
        card.Size = UDim2.new(1, 0, 0, 40)
        card.BackgroundColor3 = Color3.fromHex("#1A1A1A")
        card.ZIndex = 6
        Instance.new("UICorner", card).CornerRadius = UDim.new(0.5, 0)
        Instance.new("UIStroke", card).Color = Color3.fromHex("#2C2C2C")

        local clickBtn = Instance.new("TextButton", card)
        clickBtn.Text = text
        clickBtn.Size = UDim2.new(1, -24, 0, 26)
        clickBtn.Position = UDim2.fromScale(0.5, 0.5)
        clickBtn.AnchorPoint = Vector2.new(0.5, 0.5)
        clickBtn.BackgroundColor3 = Color3.fromHex("#5C6BC0")
        clickBtn.TextColor3 = Color3.new(1, 1, 1)
        clickBtn.TextSize = 12
        clickBtn.Font = Enum.Font.SourceSansBold
        clickBtn.ZIndex = 7
        Instance.new("UICorner", clickBtn).CornerRadius = UDim.new(0.5, 0)

        clickBtn.Activated:Connect(function()
            clickBtn.Size = UDim2.new(1, -32, 0, 22)
            TweenService:Create(clickBtn, TWEEN_INFO_FAST, {Size = UDim2.new(1, -24, 0, 26)}):Play()
            callback()
        end)
    end

    return pageMethods
end

return Library
