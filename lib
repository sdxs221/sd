}

local function MakeDraggable(gui: Frame)
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            TweenService:Create(gui, TWEEN_INFO_FAST, {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }):Play()
        end
    end)
end

local function StartSnowEffect(panel: Frame)
    local maxSnow = 12
    local snowList = {}
    local random = Random.new()
    local lastSpawn = 0
    local spawnInterval = 0.4

    RunService.RenderStepped:Connect(function(deltaTime)
        if not panel.Visible or panel.Size.X.Offset < 300 then
            for _, flake in ipairs(snowList) do
                flake.obj:Destroy()
            end
            table.clear(snowList)
            return
        end

        local currentTime = os.clock()
        if #snowList < maxSnow and (currentTime - lastSpawn) >= spawnInterval then
            lastSpawn = currentTime
            
            local flake = Instance.new("ImageLabel")
            flake.BackgroundTransparency = 1
            flake.Image = SNOW_ICONS[random:NextInteger(1, #SNOW_ICONS)]
            flake.ImageColor3 = Color3.new(1, 1, 1)
            flake.ImageTransparency = random:NextNumber(0.1, 0.4)
            
            local size = random:NextInteger(10, 16)
            flake.Size = UDim2.fromOffset(size, size)
            flake.Position = UDim2.new(random:NextNumber(0.02, 0.98), 0, 0, -16)
            flake.ZIndex = 2
            flake.Parent = panel
            
            table.insert(snowList, {
                obj = flake,
                speed = random:NextNumber(30, 55),
                drift = random:NextNumber(-8, 8),
                rotSpeed = random:NextNumber(-30, 30),
                currentRot = random:NextNumber(0, 360)
            })
        end

        for i = #snowList, 1, -1 do
            local data = snowList[i]
            local flake = data.obj
            if flake and flake.Parent then
                local currentPos = flake.Position
                local panelHeight = panel.AbsoluteSize.Y
                local currentYOffset = currentPos.Y.Offset

                if currentYOffset >= panelHeight - 25 then
                    local progress = (currentYOffset - (panelHeight - 25)) / 25
                    flake.ImageTransparency = math.clamp(0.2 + progress * 0.8, 0, 1)
                end

                if currentYOffset >= panelHeight then
                    flake:Destroy()
                    table.remove(snowList, i)
                else
                    data.currentRot = data.currentRot + data.rotSpeed * deltaTime
                    flake.Rotation = data.currentRot
                    flake.Position = UDim2.new(
                        currentPos.X.Scale,
                        currentPos.X.Offset + data.drift * deltaTime,
                        currentPos.Y.Scale,
                        currentYOffset + data.speed * deltaTime
                    )
                end
            else
                table.remove(snowList, i)
            end
        end
    end)
end

