    CloseBtn.TextSize = 12
    CloseBtn.Font = Enum.Font.SourceSansBold
    CloseBtn.ZIndex = 5
    CloseBtn.Activated:Connect(ToggleMenu)

    local flakes = {}
    local rng = Random.new()
    local lastSpawn = 0

    RunService.RenderStepped:Connect(function(dt)
        if not self.MainPanel.Visible then return end
        
        lastSpawn = lastSpawn + dt
        if lastSpawn >= 0.1 and #flakes < 40 then
            lastSpawn = 0
            local flake = Instance.new("Frame", SnowContainer)
            local size = rng:NextInteger(3, 6)
            flake.Size = UDim2.fromOffset(size, size)
            flake.Position = UDim2.new(rng:NextNumber(0, 1), 0, -0.05, 0)
            flake.BackgroundColor3 = Color3.new(1, 1, 1)
            flake.BackgroundTransparency = rng:NextNumber(0.1, 0.5)
            flake.ZIndex = 2
            Instance.new("UICorner", flake).CornerRadius = UDim.new(0.5, 0)
            
            table.insert(flakes, {
                obj = flake,
                speed = rng:NextNumber(40, 80),
                drift = rng:NextNumber(-20, 20),
                wobbleSpeed = rng:NextNumber(2, 5),
                wobbleTime = rng:NextNumber(0, 10)
            })
        end

        for i = #flakes, 1, -1 do
            local f = flakes[i]
            if f.obj and f.obj.Parent then
                f.wobbleTime = f.wobbleTime + dt
                local currentPos = f.obj.Position
                local newYOffset = f.obj.Position.Y.Offset + (f.speed * dt)
                local newXScale = currentPos.X.Scale + ((f.drift + math.sin(f.wobbleTime * f.wobbleSpeed) * 15) * dt / 380)
                
                f.obj.Position = UDim2.new(math.clamp(newXScale, 0, 1), currentPos.X.Offset, 0, newYOffset)
                
                if newYOffset >= 260 then
                    f.obj:Destroy()
                    table.remove(flakes, i)
                end
            else
                table.remove(flakes, i)
            end
        end
    end)

    local success, _ = pcall(function() self.ScreenGui.Parent = game:GetService("CoreGui") end)
    if not success then self.ScreenGui.Parent = localPlayer:WaitForChild("PlayerGui") end
    
    return self
end

